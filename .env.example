# ============================================================
# 环境变量模板（可提交 Git）
# 复制为 .env.local 后填入真实值；.env.local 已被 .gitignore 忽略
# ============================================================

# --- Notion ---
NOTION_KEY=
NOTION_PAGE_ID=
# 若使用数据库 ID，可与 NOTION_PAGE_ID 二选一
NOTION_DATABASE_ID=

# --- 博客后台 /admin 登录（middleware）---
AUTH_USER=
AUTH_PASS=
# 商户系统签发 login_token 验签密钥（HS256）；由商户部署/首次进入后台写入 Vercel
BLOG_LOGIN_JWT_SECRET=
# 设为 1 或 true 时关闭 ?auth_u=&auth_p= 明文 URL 登录（默认开启 legacy）
# DISABLE_LEGACY_URL_PASSWORD=false

# --- 兰空图床（后台上传 / Gallery 图库）---
LSKY_URL=https://img.x1file.top
# 可填 1|xxx 或 Bearer 1|xxx，代码会自动处理
LSKY_TOKEN=
# 本站转发到兰空前的单文件上限（MB），默认 50；兰空后台也需放开同等或更大限制
LSKY_MAX_UPLOAD_MB=50

# --- Gallery 图库 · Supabase（见 docs/SUPABASE_GALLERY_SETUP.md）---
# 共用 1 个 Supabase Project；多租户靠 BLOG_SITE_ID 隔离（= merchant_services.id）
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
# 本 Blog 租户 ID（商户系统部署时写入）
BLOG_SITE_ID=
# 本站图库容量上限 GB（默认 50）
GALLERY_QUOTA_GB=50

# --- 可选 ---
# 站点公网地址（轻量 SEO：canonical / Open Graph / sitemap / robots；由商户系统在部署时注入）
# NEXT_PUBLIC_SITE_URL=https://www.example.com
# NEXT_PUBLIC_THEME=gallery
# DISABLE_REMOTE_THEME_CACHE=1
# ISR 过期秒数（默认 3600；内容更新主要靠后台保存触发的按需刷新）
# NEXT_REVALIDATE_SECONDS=3600
# 预热请求使用的博客公网地址（与 admin 不同域时必填，如 https://你的博客域名.com）
# BLOG_PUBLIC_URL=https://example.com
# Vercel 部署保护开启时，填入 Automation Bypass Secret 以便 ISR 预热穿透 CDN
# VERCEL_AUTOMATION_BYPASS_SECRET=
# 封面 blur 占位需远程探测时开启（默认关闭以省 Vercel CPU，SaaS 多租户建议保持关闭）
# ENABLE_REMOTE_IMAGE_PROBE=1
